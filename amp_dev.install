/**
 * Test Resource Beta — CPU resource with minimal data.
 */
function amp_dev_install_create_rp_beta() {
  $resource_id = 'test-beta-9998';
  $node = _amp_dev_find_resource($resource_id);

  $values = [
    'type' => 'access_active_resources_from_cid',
    'title' => 'Test Resource Beta',
    'status' => 1,
    'field_cider_resource_id' => $resource_id,
    'field_access_global_resource_id' => 'beta.test.access-ci.org',
    'field_cider_resource_type' => 'Compute',
    'field_cider_latest_status' => 'production',
    'field_access_org_name' => 'Beta State University',
    'field_rp_description' => [
      'value' => '<p>Test Resource Beta is a CPU-only cluster for general-purpose computing workloads. This test resource has minimal documentation to verify that the template handles sparse data gracefully.</p>',
      'summary' => 'CPU-only cluster for general-purpose computing.',
      'format' => 'full_html',
    ],
    'field_rp_listing' => FALSE,
    'field_domain_access' => ['amp_cyberinfrastructure_org'],
  ];

  if ($node) {
    foreach ($values as $key => $value) {
      if ($key !== 'type') {
        $node->set($key, $value);
      }
    }
    $node->save();
  }
  else {
    $node = Node::create($values);
    $node->save();
  }

  \Drupal::logger('amp_dev.install')->notice('Created Test Resource Beta (nid: ' . $node->id() . ')');
}

