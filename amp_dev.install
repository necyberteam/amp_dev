/**
 * Test Resource Group — groups Alpha and Beta together.
 */
function amp_dev_install_create_rp_resource_group() {
  // Delete existing test resource group.
  $existing = \Drupal::entityTypeManager()
    ->getStorage('node')
    ->loadByProperties([
      'type' => 'resource_group',
      'title' => 'Test Resource Group',
    ]);
  foreach ($existing as $node) {
    $node->delete();
  }

  // Find Alpha and Beta by resource ID.
  $alpha = _amp_dev_find_resource('test-alpha-9999');
  $beta = _amp_dev_find_resource('test-beta-9998');

  $resources = [];
  if ($alpha) {
    $resources[] = ['target_id' => $alpha->id()];
  }
  if ($beta) {
    $resources[] = ['target_id' => $beta->id()];
  }

  $node = Node::create([
    'type' => 'resource_group',
    'title' => 'Test Resource Group',
    'status' => 1,
    'field_rp_description' => [
      'value' => '<p>A test resource group for CI testing. This group combines Alpha and Beta resources for unified documentation.</p>',
      'summary' => 'A test resource group for CI testing.',
      'format' => 'full_html',
    ],
    'field_cider_resources' => $resources,
    'field_rp_listing' => TRUE,
    'field_domain_access' => ['amp_cyberinfrastructure_org'],
    // Inheritable defaults: child Resources that leave these empty will pick
    // them up via the preprocess fallback (see asp-theme/aspTheme.theme).
    // Alpha sets its own support/office/software so it should OVERRIDE these;
    // Beta sets none of them so it should INHERIT all three from the Group.
    'field_rp_support_links' => [
      ['uri' => 'https://group.test.example.edu/user-guide', 'title' => 'Group User Guide'],
      ['uri' => 'https://group.test.example.edu/tickets', 'title' => 'Group Ticket System'],
    ],
    'field_rp_office_hours' => [
      'uri' => 'https://group.test.example.edu/office-hours',
      'title' => 'Fri 3-5 PM EST',
    ],
    'field_rp_software_list_url' => [
      'uri' => 'https://group.test.example.edu/software',
      'title' => 'View all group software',
    ],
  ]);
  $node->save();

  \Drupal::logger('amp_dev.install')->notice('Created Test Resource Group (nid: ' . $node->id() . ')');
}

/**
 * Find a resource node by field_cider_resource_id.
 */
function _amp_dev_find_resource($resource_id) {
  $nids = \Drupal::entityTypeManager()
    ->getStorage('node')
    ->getQuery()
    ->condition('type', 'access_active_resources_from_cid')
    ->condition('field_cider_resource_id', $resource_id)
    ->accessCheck(FALSE)
    ->range(0, 1)
    ->execute();

  if (empty($nids)) {
    return NULL;
  }

  return Node::load(reset($nids));
}

/**
 * Create a paragraph entity (unsaved).
 */
function _amp_dev_create_paragraph($type, array $fields) {
  $values = ['type' => $type];
  foreach ($fields as $field_name => $value) {
    $values[$field_name] = $value;
  }
  return Paragraph::create($values);
}

/**
 * Attach paragraphs to a node field with proper parent info.
 */
function _amp_dev_attach_paragraphs($node, $field_name, array $paragraphs) {
  $refs = [];
  foreach ($paragraphs as $paragraph) {
    $paragraph->setParentEntity($node, $field_name);
    $paragraph->save();
    $refs[] = [
      'target_id' => $paragraph->id(),
      'target_revision_id' => $paragraph->getRevisionId(),
    ];
  }
  $node->set($field_name, $refs);
}

/**
 * Clear paragraph references from a node before updating.
 */
function _amp_dev_clear_paragraphs($node, array $field_names) {
  foreach ($field_names as $field_name) {
    if (!$node->hasField($field_name)) {
      continue;
    }
    foreach ($node->get($field_name) as $ref) {
      $paragraph = $ref->entity;
      if ($paragraph) {
        $paragraph->delete();
      }
    }
    $node->set($field_name, []);
  }
}
